# Letsync (OpenCart -> DayOneMart sync)
LETSYNC_TOKEN=change-me-shared-secret
LETSYNC_MODULE_ID=1
LETSYNC_OC_LANGUAGE_ID=1
LETSYNC_IMAGE_BASE_URL=https://www.your-opencart-store.com/image
LETSYNC_IMAGE_DISK=public
LETSYNC_QUEUE=letsync

# Read-only OpenCart database connection
OC_DB_HOST=127.0.0.1
OC_DB_PORT=3306
OC_DB_DATABASE=opencart_db
OC_DB_USERNAME=opencart_user
OC_DB_PASSWORD="your-password"
OC_DB_PREFIX=oc_
